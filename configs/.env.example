# OpenClaw Secure Deployment - Environment Variables
# Reference: https://github.com/munnam77/awesome-openclaw-security
#
# IMPORTANT: This file is a TEMPLATE. Copy it to .env and fill in your values.
# NEVER commit .env to version control.
#
# For production deployments, prefer Docker secrets over environment variables.
# See guides/credential-management.md for details.
#
# Usage:
#   cp configs/.env.example .env
#   chmod 600 .env
#   # Edit values below

# =============================================================================
# Gateway Configuration
# =============================================================================

# Bind address: ALWAYS use 127.0.0.1 in production (never 0.0.0.0)
OPENCLAW_GATEWAY_HOST=127.0.0.1

# Gateway port (default: 8765)
OPENCLAW_GATEWAY_PORT=8765

# Log level: debug, info, warn, error
OPENCLAW_LOG_LEVEL=info

# Log format: json (recommended for production), text (for development)
OPENCLAW_LOG_FORMAT=json

# =============================================================================
# Authentication
# =============================================================================

# Gateway authentication token
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT: In production, use Docker secrets instead of this env var.
# OPENCLAW_AUTH_TOKEN=CHANGE_ME_generate_a_strong_token

# Admin token (for management endpoints, separate from gateway auth)
# OPENCLAW_ADMIN_TOKEN=CHANGE_ME_generate_another_strong_token

# =============================================================================
# Rate Limiting
# =============================================================================

# Maximum requests per minute per IP
OPENCLAW_RATE_LIMIT_RPM=60

# Maximum concurrent connections per IP
OPENCLAW_MAX_CONNECTIONS_PER_IP=5

# Ban duration in seconds for IPs exceeding rate limits
OPENCLAW_BAN_DURATION=300

# =============================================================================
# Session Management
# =============================================================================

# Idle session timeout in seconds (default: 1800 = 30 minutes)
OPENCLAW_SESSION_IDLE_TIMEOUT=1800

# Absolute session timeout in seconds (default: 28800 = 8 hours)
OPENCLAW_SESSION_ABSOLUTE_TIMEOUT=28800

# =============================================================================
# Skills Configuration
# =============================================================================

# Skills directory path (mounted read-only in Docker)
OPENCLAW_SKILLS_DIR=/app/skills

# Enable skill sandboxing (recommended: true)
OPENCLAW_SKILL_SANDBOX=true

# Block skill outbound network by default (recommended: true)
OPENCLAW_SKILL_NETWORK_DENY=true

# =============================================================================
# TLS (if terminating at gateway, not at nginx)
# =============================================================================

# OPENCLAW_TLS_ENABLED=false
# OPENCLAW_TLS_CERT=/etc/openclaw/tls/cert.pem
# OPENCLAW_TLS_KEY=/etc/openclaw/tls/key.pem

# =============================================================================
# Docker / Container
# =============================================================================

# Container timezone
TZ=UTC

# User/group ID for non-root execution
OPENCLAW_UID=1001
OPENCLAW_GID=1001

# =============================================================================
# External Services (use Docker secrets for production)
# =============================================================================

# Database (if applicable)
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=openclaw
# DB_USER=openclaw
# DB_PASSWORD=CHANGE_ME

# Redis (if applicable for caching/sessions)
# REDIS_URL=redis://127.0.0.1:6379/0

# =============================================================================
# Monitoring
# =============================================================================

# Enable Prometheus metrics endpoint (bind to localhost only)
# OPENCLAW_METRICS_ENABLED=false
# OPENCLAW_METRICS_PORT=9090
